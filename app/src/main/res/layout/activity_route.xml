<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen Map -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/routeMapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top navigation info bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/navInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/primary"
        android:layout_marginBottom="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvNextInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating route…"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- m"
                    android:textSize="13sp"
                    android:textColor="#AADBEAFE" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="13sp"
                    android:textColor="#AADBEAFE" />

                <TextView
                    android:id="@+id/tvETA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- min"
                    android:textSize="13sp"
                    android:textColor="#AADBEAFE" />

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom control panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/surface"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/fallDetectionRow"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_fall_detection"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_sensors"
                    android:contentDescription="Fall Detection"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Fall Detection"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvFallStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="6dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Go to sensors"
                    app:tint="@color/text_secondary" />
            </LinearLayout>
            <!-- PRIMARY ACTION: Change Destination -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeDestination"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                android:text="Change Destination"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                app:icon="@drawable/ic_edit_location"
                app:iconSize="20dp"
                app:iconGravity="textStart"
                app:cornerRadius="14dp" />

            <!-- SECONDARY ACTIONS: Utility & Emergency split row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Stop Walk -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStopWalk"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Stop Walk"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    app:icon="@drawable/ic_stop"
                    app:iconSize="18dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/divider" />

                <!-- Emergency SOS -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSOS"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="SOS"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/error"
                    app:icon="@drawable/ic_sos"
                    app:iconSize="18dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>